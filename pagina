<script>
let carrito = [];

function agregar(nombre, precio) {
    carrito.push({nombre, precio});
    mostrar();
}

function mostrar() {
    let lista = document.getElementById("lista");
    lista.innerHTML = "";
    carrito.forEach(item => {
        let li = document.createElement("li");
        li.textContent = item.nombre + " Q" + item.precio;
        lista.appendChild(li);
    });
}

function enviarWhatsApp() {
    let telefono = "50259472780";

    let nombre = document.getElementById("nombre").value;
    let direccion = document.getElementById("direccion").value;
    let tel = document.getElementById("telefonoCliente").value;

    let mensaje = "Pedido:%0A";

    carrito.forEach(item => {
        mensaje += "- " + item.nombre + " Q" + item.precio + "%0A";
    });

    mensaje += "%0ACliente: " + nombre;
    mensaje += "%0ADirección: " + direccion;
    mensaje += "%0ATeléfono: " + tel;

    window.open("https://wa.me/" + telefono + "?text=" + mensaje, "_blank");
}
</script>

